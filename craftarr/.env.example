# ============================================================
# MCManager — Configuration
# Copiez ce fichier en .env et ajustez les valeurs
# ============================================================

# --- Authentification ---
JWT_SECRET=change-me-in-production-use-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Ports ---
UI_PORT=8080
BACKEND_PORT=3000

# --- Chiffrement (32 caractères exactement pour AES-256) ---
ENCRYPTION_KEY=01234567890123456789012345678901

# --- APIs Modpacks (optionnel, configurable aussi dans l'UI) ---
# CurseForge : https://console.curseforge.com/
CURSEFORGE_API_KEY=

# Modrinth n'exige pas de clé mais permet un rate limit plus élevé
MODRINTH_API_KEY=

# --- Auto-update ---
UPDATE_CHECK_INTERVAL_HOURS=6
